# Vercel KV – wird automatisch von Vercel gesetzt wenn KV-Store verbunden ist
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Admin-Schutz: ein beliebiges, langes zufälliges Passwort
# Generieren z.B. mit: openssl rand -hex 32
ADMIN_SECRET=dein-geheimes-passwort-hier

# Wird im Browser gebraucht um den Auth-Header zu setzen
# Muss identisch mit ADMIN_SECRET sein
NEXT_PUBLIC_ADMIN_SECRET=dein-geheimes-passwort-hier
